# ============================================================
#  construtora-financeiro — exemplo de variáveis de ambiente
#  Copie para `.env` e ajuste. NUNCA versione o `.env` real.
# ============================================================

# ---- Banco de dados (PostgreSQL / Supabase) ----
POSTGRES_DB=construtora
POSTGRES_USER=construtora
POSTGRES_PASSWORD=construtora
# Para Supabase use a connection string do painel (Settings > Database).
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/construtora
SPRING_DATASOURCE_USERNAME=construtora
SPRING_DATASOURCE_PASSWORD=construtora

# ---- JWT ----
# Segredo de no mínimo 32 bytes (256 bits). Gere com: openssl rand -base64 48
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-bem-grande-256-bits
JWT_EXPIRATION_MS=86400000

# ---- CORS ----
# Origens permitidas separadas por vírgula (frontend local + Vercel).
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,https://seu-app.vercel.app

# ---- SMTP (notificações por e-mail) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=nao-responder@construtora.com.br

# ---- Usuário admin inicial (seed) ----
APP_ADMIN_EMAIL=admin@construtora.com.br
APP_ADMIN_PASSWORD=Admin@123

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8080/api
