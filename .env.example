# ============================================================
#  construtora-financeiro — exemplo de variáveis de ambiente
#  Copie para `.env` e ajuste. NUNCA versione o `.env` real.
# ============================================================

# ---- Domínio (produção VPS/Hostinger) ----
# Usado pelo Caddy para SSL automático (Let's Encrypt) e pelo CORS do backend.
# Em desenvolvimento local não precisa preencher.
DOMAIN=erp.minhaempresa.com.br

# ---- Banco de dados (PostgreSQL local via docker-compose) ----
POSTGRES_DB=construtora
POSTGRES_USER=construtora
POSTGRES_PASSWORD=troque_esta_senha_do_banco

# Para Supabase, ignore as 3 linhas acima e preencha abaixo:
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres.<ref>
# SPRING_DATASOURCE_PASSWORD=<senha-do-supabase>

# ---- JWT ----
# Segredo de no mínimo 32 bytes (256 bits). Gere com: openssl rand -base64 48
JWT_SECRET=troque-este-segredo-por-um-valor-aleatorio-bem-grande-256-bits
JWT_EXPIRATION_MS=86400000

# ---- Licenciamento ----
# Segredo HMAC-SHA256 para assinar/verificar chaves de licença.
# DEVE ser único por instalação. Gere com: openssl rand -base64 48
# Chaves geradas com um segredo são inválidas em outra VM com segredo diferente.
LICENSE_SECRET=troque-este-segredo-de-licenca-por-um-valor-aleatorio-256-bits

# ---- CORS ----
# Em produção com Caddy (VPS), frontend e backend ficam no mesmo domínio,
# então apenas https://<DOMAIN> é necessário.
# Em desenvolvimento local, adicione também http://localhost:5173.
APP_CORS_ALLOWED_ORIGINS=https://erp.minhaempresa.com.br,http://localhost:5173

# ---- SMTP (notificações por e-mail) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=nao-responder@construtora.com.br

# ---- Usuário admin inicial (seed) ----
APP_ADMIN_EMAIL=admin@construtora.com.br
APP_ADMIN_PASSWORD=Troque@123

# ---- Frontend (apenas para docker compose local sem Caddy) ----
# Em produção com Caddy o VITE_API_BASE_URL é injetado pelo docker-compose.prod.yml
VITE_API_BASE_URL=http://localhost:8080/api
